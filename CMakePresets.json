{
	"version": 9,
	"cmakeMinimumRequired": {
		"major": 3,
		"minor": 30,
		"patch": 0
	},
	"configurePresets": [
		{
			"name": "debug",
			"displayName": "Debug",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build/debug",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
				"TRIVIAL_ENABLE_ASSERTS": "ON",
				"TRIVIAL_ENABLE_SLOW_ASSERTS": "OFF",
				"TRIVIAL_ENABLE_LOGGING": "ON",
				"TRIVIAL_ENABLE_SIMD": "ON",
				"TRIVIAL_ENABLE_VULKAN_VALIDATION": "ON",
				"TRIVIAL_ENABLE_TRACY": "OFF",
				"TRIVIAL_MATH_DISABLE_SIMD_BACKEND": "OFF",
				"TRIVIAL_MATH_DISABLE_FMA": "OFF"
			}
		},
		{
			"name": "debug-slow",
			"displayName": "Debug + Slow Assertions",
			"inherits": "debug",
			"binaryDir": "${sourceDir}/build/debug-slow",
			"cacheVariables": {
				"TRIVIAL_ENABLE_SLOW_ASSERTS": "ON"
			}
		},
		{
			"name": "debug-tracy",
			"displayName": "Debug + Tracy",
			"inherits": "debug",
			"binaryDir": "${sourceDir}/build/debug-tracy",
			"cacheVariables": {
				"TRIVIAL_ENABLE_TRACY": "ON"
			}
		},
		{
			"name": "release",
			"displayName": "Release",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build/release",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release",
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
				"TRIVIAL_ENABLE_ASSERTS": "OFF",
				"TRIVIAL_ENABLE_SLOW_ASSERTS": "OFF",
				"TRIVIAL_ENABLE_LOGGING": "OFF",
				"TRIVIAL_ENABLE_SIMD": "ON",
				"TRIVIAL_ENABLE_VULKAN_VALIDATION": "OFF",
				"TRIVIAL_ENABLE_TRACY": "OFF",
				"TRIVIAL_MATH_DISABLE_SIMD_BACKEND": "OFF",
				"TRIVIAL_MATH_DISABLE_FMA": "OFF"
			}
		},
		{
			"name": "relwithdebinfo",
			"displayName": "Release With Debug Info",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build/relwithdebinfo",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "RelWithDebInfo",
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
				"TRIVIAL_ENABLE_ASSERTS": "OFF",
				"TRIVIAL_ENABLE_SLOW_ASSERTS": "OFF",
				"TRIVIAL_ENABLE_SIMD": "ON",
				"TRIVIAL_ENABLE_LOGGING": "ON",
				"TRIVIAL_ENABLE_VULKAN_VALIDATION": "OFF",
				"TRIVIAL_ENABLE_TRACY": "OFF",
				"TRIVIAL_MATH_DISABLE_SIMD_BACKEND": "OFF",
				"TRIVIAL_MATH_DISABLE_FMA": "OFF"
			}
		},
		{
			"name": "relwithdebinfo-tracy",
			"displayName": "Release With Debug Info + Tracy",
			"inherits": "relwithdebinfo",
			"binaryDir": "${sourceDir}/build/relwithdebinfo-tracy",
			"cacheVariables": {
				"TRIVIAL_ENABLE_TRACY": "ON"
			}
		}
	],
	"buildPresets": [
		{
			"name": "debug",
			"configurePreset": "debug"
		},
		{
			"name": "debug-slow",
			"configurePreset": "debug-slow"
		},
		{
			"name": "debug-tracy",
			"configurePreset": "debug-tracy"
		},
		{
			"name": "release",
			"configurePreset": "release"
		},
		{
			"name": "relwithdebinfo",
			"configurePreset": "relwithdebinfo"
		},
		{
			"name": "relwithdebinfo-tracy",
			"configurePreset": "relwithdebinfo-tracy"
		}
	]
}
